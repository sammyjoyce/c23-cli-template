{
  "opencli": "0.1",
  "info": {
    "title": "C23 TUI + CLI Starter",
    "description": "A ready-to-use C23 starter for command-line tools and ncurses terminal UIs.",
    "version": "0.1.0",
    "contact": {
      "name": "Your Name",
      "url": "https://github.com/yourusername/yourproject"
    },
    "license": {
      "name": "MIT License",
      "identifier": "MIT"
    }
  },
  "conventions": {
    "groupOptions": false,
    "optionArgumentSeparator": " "
  },
  "arguments": [
    {
      "name": "command",
      "required": true,
      "ordinal": 1,
      "arity": {
        "minimum": 1,
        "maximum": 1
      },
      "description": "The command to execute"
    }
  ],
  "options": [
    {
      "name": "help",
      "required": false,
      "aliases": ["h"],
      "arguments": [],
      "description": "Show help message and exit"
    },
    {
      "name": "version",
      "required": false,
      "aliases": [],
      "arguments": [],
      "description": "Show version information and exit"
    },
    {
      "name": "debug",
      "required": false,
      "aliases": ["d"],
      "arguments": [],
      "description": "Enable debug output (DEBUG level logs)"
    },
    {
      "name": "quiet",
      "required": false,
      "aliases": ["q"],
      "arguments": [],
      "description": "Suppress non-essential output"
    },
    {
      "name": "verbose",
      "required": false,
      "aliases": ["v"],
      "arguments": [],
      "description": "Enable verbose output"
    },
    {
      "name": "json",
      "required": false,
      "aliases": [],
      "arguments": [],
      "description": "Output a versioned JSON response where supported"
    },
    {
      "name": "plain",
      "required": false,
      "aliases": [],
      "arguments": [],
      "description": "Output plain text without colors"
    },
    {
      "name": "no-color",
      "required": false,
      "aliases": [],
      "arguments": [],
      "description": "Disable colored output"
    },
    {
      "name": "config",
      "required": false,
      "aliases": ["c"],
      "arguments": [
        {
          "name": "path",
          "required": true,
          "ordinal": 1,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Path to configuration file"
        }
      ],
      "description": "Specify configuration file path"
    }
  ],
  "commands": [
    {
      "name": "hello",
      "description": "Print a greeting message",
      "options": [],
      "arguments": [
        {
          "name": "name",
          "required": false,
          "ordinal": 1,
          "arity": {
            "minimum": 0,
            "maximum": 1
          },
          "description": "Name to greet (default: World)"
        }
      ],
      "examples": [
        "myapp hello",
        "myapp hello Alice"
      ]
    },
    {
      "name": "echo",
      "description": "Echo the provided text",
      "options": [],
      "arguments": [
        {
          "name": "text",
          "required": false,
          "ordinal": 1,
          "arity": {
            "minimum": 0,
            "maximum": null
          },
          "description": "Text to echo"
        }
      ],
      "examples": [
        "myapp echo Hello World",
        "myapp echo"
      ]
    },
    {
      "name": "info",
      "description": "Display application information",
      "options": [],
      "arguments": [],
      "examples": [
        "myapp info",
        "myapp --json info"
      ]
    },
    {
      "name": "doctor",
      "description": "Run starter diagnostics for build metadata, output mode, and optional features",
      "options": [
        {
          "name": "deep",
          "required": false,
          "aliases": [],
          "arguments": [],
          "description": "Also exercise the optional TUI runtime when a TTY is available"
        }
      ],
      "arguments": [],
      "examples": [
        "myapp doctor",
        "myapp --json doctor"
      ]
    },
    {
      "name": "menu",
      "description": "Launch interactive TUI showcase (requires an ncurses-enabled build)",
      "options": [],
      "arguments": [],
      "examples": [
        "zig build -Denable-tui=true run -- menu"
      ],
      "metadata": {
        "requires": "ncurses",
        "interactive": true
      }
    },
    {
      "name": "opencli",
      "description": "Print the OpenCLI specification as JSON",
      "options": [],
      "arguments": [],
      "examples": [
        "myapp opencli"
      ]
    }
  ],
  "exitCodes": [
    {
      "code": 0,
      "description": "Success"
    },
    {
      "code": 1,
      "description": "Invalid argument"
    },
    {
      "code": 2,
      "description": "Invalid or unknown command"
    },
    {
      "code": 3,
      "description": "Configuration file error"
    },
    {
      "code": 4,
      "description": "Configuration file parse error"
    },
    {
      "code": 5,
      "description": "Configuration file has invalid values"
    },
    {
      "code": 6,
      "description": "Missing required argument"
    },
    {
      "code": 7,
      "description": "Unknown option"
    },
    {
      "code": 10,
      "description": "Memory allocation error"
    },
    {
      "code": 11,
      "description": "I/O error"
    },
    {
      "code": 12,
      "description": "Permission denied"
    },
    {
      "code": 13,
      "description": "Internal error"
    },
    {
      "code": 14,
      "description": "Thread/mutex error"
    },
    {
      "code": 15,
      "description": "Resource exhaustion"
    },
    {
      "code": 16,
      "description": "Signal handling error"
    },
    {
      "code": 17,
      "description": "File or resource not found"
    },
    {
      "code": 20,
      "description": "Invalid data format"
    },
    {
      "code": 21,
      "description": "Parse error"
    },
    {
      "code": 22,
      "description": "Validation failed"
    },
    {
      "code": 23,
      "description": "Numeric overflow"
    },
    {
      "code": 24,
      "description": "Numeric underflow"
    },
    {
      "code": 25,
      "description": "Value out of range"
    }
  ],
  "examples": [
    "myapp hello",
    "myapp hello Alice",
    "myapp echo Hello World",
    "myapp echo",
    "myapp info",
    "myapp --json info",
    "myapp doctor",
    "myapp --json doctor",
    "zig build -Denable-tui=true run -- menu",
    "myapp opencli",
    "myapp --help",
    "myapp --version"
  ],
  "interactive": false,
  "metadata": [
    {
      "name": "environment",
      "value": {
        "APP_LOG_LEVEL": "Set logging verbosity: ERROR, WARNING, INFO, DEBUG (default: ERROR)",
        "NO_COLOR": "Disable colored output when set"
      }
    },
    {
      "name": "configuration",
      "value": {
        "location": "~/.config/myapp/config.json",
        "format": "Flat JSON object with boolean debug, quiet, verbose, no_color, json_output, and plain_output keys",
        "precedence": "CLI args > Environment > Config file > Defaults"
      }
    },
    {
      "name": "build",
      "value": {
        "system": "Zig build system",
        "compiler": "Zig cc (Clang/LLVM)",
        "standard": "C23"
      }
    }
  ]
}
